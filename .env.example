# Notion API
# https://www.notion.so/my-integrations で Internal Integration を作って取得
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=00000000-0000-0000-0000-000000000000
NOTION_DATA_SOURCE_ID=00000000-0000-0000-0000-000000000000

# Notion 親ページ ID (案件スカウト用ページのURL末尾のハッシュ部分)
NOTION_PARENT_PAGE_ID=000000000000000000000000000000

# Gmail SMTP
# アプリパスワード: https://myaccount.google.com/apppasswords で生成
# (2段階認証ON必須)
GMAIL_FROM=your_email@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
GMAIL_TO=your_email@gmail.com

# スクレイピング設定
FETCH_PAGES_PER_CATEGORY=2
FETCH_DELAY_SECONDS=60
DETAIL_DELAY_SECONDS=30
FETCH_USER_AGENT=YourScraper/1.0 (contact: your_email@gmail.com)
